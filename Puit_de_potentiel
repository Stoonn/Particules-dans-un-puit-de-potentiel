import tkinter as tk
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
from numpy import *
from matplotlib.figure import Figure


class InterfaceGraphique(tk.Tk):

    def __init__(self):
        tk.Tk.__init__(self)

        # Configuration de la grille
        self.grid_rowconfigure(0, weight=0)
        self.grid_columnconfigure(0, weight=1)
        self.grid_columnconfigure(1, weight=7)

        # ici ce sera la largeur a du puit
        self.Largeurtext = tk.Spinbox(self, from_=0,
                                      to=100, width=5, command=self.update)
        self.Largeurtext.grid(row=0, column=0, sticky='ne')

        largeur = tk.Label(self, text='largeur a :')
        largeur.grid(row=0, column=0, sticky='nw')

        # Bouton a check permettant d'activer et désactiver le potentiel infini
        self.var1 = tk.BooleanVar()
        self.infinibout = tk.Checkbutton(self, text='potentiel infini',
                                         variable=self.var1,
                                         command=self.infini)
        self.infinibout.grid(row=1, column=0, sticky='nw')

        # Bouton potentiel v
        self.Hauteur_puit = tk.Spinbox(self, from_=0, to=100, width=3)
        self.Hauteur_puit.grid(row=2, column=0, sticky='ne')

        self.hauteur_text = tk.Label(self, text='potentiel v :')
        self.hauteur_text.grid(row=2, column=0, sticky='nw')

        # figure matplotlib
        self.fig = Figure()
        self.ax = self.fig.add_subplot(111)

        # insertion dans subplot
        self.canvas = FigureCanvasTkAgg(self.fig)
        self.canvas.get_tk_widget().grid(row=0,
                                         rowspan=40, column=1, sticky='nsew')

        # fonction pour afficher le graphe
        # self.modif_graphe()

    # fonction permettant de passer s'un puit fini à infini
    def infini(self):

        if self.var1.get():
            v = 0
            self.Hauteur_puit.destroy()
            self.hauteur_text.destroy()
        else:
            self.Hauteur_puit = tk.Spinbox(self, from_=0, to=100, width=3)
            self.Hauteur_puit.grid(row=2, column=0, sticky='ne')
            self.hauteur_text = tk.Label(self, text='potentiel v :')
            self.hauteur_text.grid(row=2, column=0, sticky='nw')
            v = self.Hauteur_puit.get()
        return v

    # fonction pour modifier le graphe en temps réel
    # def modif_graphe(self):

    # fonction pour update les xlim
    def update(self):
        a = self.Largeurtext.get()
        self.ax.set_xlim(-int(a)-2, int(a)+2)
        self.canvas.draw()


Interface = InterfaceGraphique()
Interface.mainloop()
